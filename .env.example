# WordPress GraphQL endpoint (WPGraphQL)
NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://cms.ausrealestatenews.com.au/graphql

# WordPress REST API base (for n8n webhooks if needed)
WP_REST_BASE=https://cms.ausrealestatenews.com.au/wp-json

# Frontend site URL
NEXT_PUBLIC_SITE_URL=https://stg.ausrealestatenews.com.au

# n8n webhook base URL
N8N_WEBHOOK_BASE=https://automation.ausrealestatenews.com.au/webhook

# Revalidation secret (set to a strong random string)
REVALIDATION_SECRET=your-revalidation-secret-here

# MCP server configuration
MCP_SERVER_URL=https://cms.ausrealestatenews.com.au/mcp-server/
MCP_SERVER_ID=ausrealestate-news

# WordPress API keys for MCP auth
MCP_API_KEY=your-mcp-api-key
WP_APP_PASSWORD=your-wordpress-application-password

# GraphQL auth (Basic Auth) for server-side Apollo client
WP_USER=kamal@brandaid.au
WP_APP_PASSWORD=your-wordpress-application-password

# Google Maps API key (for agency map)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Auth base URL (for NextAuth or equivalent)
NEXTAUTH_URL=https://stg.ausrealestatenews.com.au

# Environment
NODE_ENV=development
PORT=3000
